{
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Uid=${DB_USER};Pwd=${DB_PASSWORD};"
  },
  "JwtSettings": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}",
    "ExpiryInMinutes": 120
  },
  "DailyCleanupSettings": {
    "Enabled": true,
    "ExecuteTime": "02:00",
    "PickupCodeUnusedTimeoutHours": 24,
    "StartupDelaySeconds": 60,
    "HardCleanupEnabled": true,
    "HardCleanupExecuteTime": "03:00",
    "SoftDeleteRetentionMonths": 6
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information",
      "LeftoverShare.API.BackgroundServices": "Information",
      "LeftoverShare.API.Services": "Information"
    }
  },
  "AllowedHosts": "*"
}
